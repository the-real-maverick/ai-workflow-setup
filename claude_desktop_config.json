{
  "mcpServers": {
    "obsidian-vault": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "VAULT_PATH_PLACEHOLDER"
      ]
    },
    "perplexity-search": {
      "command": "npx",
      "args": ["-y", "server-perplexity-ask"],
      "env": {
        "PERPLEXITY_API_KEY": "PERPLEXITY_API_KEY_PLACEHOLDER"
      }
    }
  }
}
